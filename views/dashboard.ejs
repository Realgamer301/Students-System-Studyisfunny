<%- include('partials/header') %>

<h3 class="mb-4">📊 نظرة عامة</h3>

<!-- كروت الإحصائيات -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card shadow-sm border-0 text-center p-3">
      <div class="text-muted small">إجمالي الطلاب</div>
      <div class="fs-3 fw-bold text-primary"><%= totalStudents %></div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card shadow-sm border-0 text-center p-3">
      <div class="text-muted small">إجمالي أرصدة الطلاب</div>
      <div class="fs-3 fw-bold text-success"><%= totalBalance %> ج</div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card shadow-sm border-0 text-center p-3">
      <div class="text-muted small">طلاب محتاجين تجديد</div>
      <div class="fs-3 fw-bold text-danger"><%= lowBalanceCount %></div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card shadow-sm border-0 text-center p-3">
      <div class="text-muted small">حصص اليوم</div>
      <div class="fs-3 fw-bold text-info"><%= todaySessions %></div>
      <div class="text-muted small mt-1">حضور اليوم: <%= todayAttendance %></div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <!-- جراف الحضور آخر 7 أيام -->
  <div class="col-md-7">
    <div class="card shadow-sm p-3">
      <h6 class="mb-3">الحضور في آخر 7 أيام</h6>
      <canvas id="attendanceChart" height="120"></canvas>
    </div>
  </div>

  <!-- توزيع الطلاب على السناتر -->
  <div class="col-md-5">
    <div class="card shadow-sm p-3">
      <h6 class="mb-3">توزيع الطلاب على السناتر</h6>
      <canvas id="centersChart" height="180"></canvas>
    </div>
  </div>
</div>

<div class="row g-3">
  <!-- توزيع الطلاب على المواد -->
  <div class="col-md-5">
    <div class="card shadow-sm p-3">
      <h6 class="mb-3">توزيع الطلاب على المواد</h6>
      <canvas id="subjectsChart" height="180"></canvas>
    </div>
  </div>

  <!-- آخر النشاطات -->
  <div class="col-md-7">
    <div class="card shadow-sm p-3">
      <h6 class="mb-3">آخر النشاطات</h6>
      <ul class="list-group list-group-flush">
        <% if (activityFeed.length === 0) { %>
          <li class="list-group-item text-muted small">لا يوجد نشاط حتى الآن</li>
        <% } %>
        <% activityFeed.forEach(item => { %>
          <li class="list-group-item small d-flex justify-content-between">
            <span><%= item.text %></span>
            <span class="text-muted" style="white-space: nowrap;">
              <%= new Date(item.time).toLocaleTimeString('ar-EG', { hour: '2-digit', minute: '2-digit' }) %>
            </span>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // جراف الحضور آخر 7 أيام
  const dayCounts = <%- JSON.stringify(dayCounts) %>;
  new Chart(document.getElementById('attendanceChart'), {
    type: 'bar',
    data: {
      labels: Object.keys(dayCounts),
      datasets: [{
        label: 'عدد الحضور',
        data: Object.values(dayCounts),
        backgroundColor: '#0d6efd',
      }],
    },
    options: { plugins: { legend: { display: false } } },
  });

  // جراف توزيع السناتر
  const centerCounts = <%- JSON.stringify(centerCounts) %>;
  new Chart(document.getElementById('centersChart'), {
    type: 'doughnut',
    data: {
      labels: Object.keys(centerCounts),
      datasets: [{
        data: Object.values(centerCounts),
        backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#dc3545', '#6610f2', '#fd7e14', '#20c997'],
      }],
    },
  });

  // جراف توزيع المواد
  const subjectCounts = <%- JSON.stringify(subjectCounts) %>;
  new Chart(document.getElementById('subjectsChart'), {
    type: 'doughnut',
    data: {
      labels: Object.keys(subjectCounts),
      datasets: [{
        data: Object.values(subjectCounts),
        backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#dc3545', '#6610f2', '#fd7e14'],
      }],
    },
  });
</script>

<%- include('partials/footer') %>