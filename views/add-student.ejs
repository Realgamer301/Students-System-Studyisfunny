
<%- include('partials/header') %>

  <div class="container py-5">
    <div class="card shadow-sm mx-auto" style="max-width: 600px;">
      <div class="card-body p-4">
        <h3 class="mb-4 text-center">تسجيل طالب جديد</h3>

        <form action="/students" method="POST">
          <div class="mb-3">
            <label class="form-label">اسم الطالب</label>
            <input type="text" name="name" class="form-control" required>
          </div>

          <div class="mb-3">
            <label class="form-label">رقم تليفون الطالب</label>
            <input type="text" name="phone" class="form-control" required>
          </div>

          <div class="mb-3">
            <label class="form-label">رقم تليفون ولي الأمر</label>
            <input type="text" name="parent_phone" class="form-control" required>
          </div>

          <div class="mb-3">
            <label class="form-label">المادة</label>
            <select name="subject_id" id="subjectSelect" class="form-select" required>
              <option value="">-- اختر المادة --</option>
              <% subjects.forEach(subj => { %>
                <option value="<%= subj.id %>" data-price="<%= subj.default_price %>">
                  <%= subj.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">السنتر</label>
            <select name="center_id" class="form-select" required>
              <option value="">-- اختر السنتر --</option>
              <% centers.forEach(center => { %>
                <option value="<%= center.id %>"><%= center.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">سعر الحصة (يتعدل تلقائي، وقابل للتغيير)</label>
            <input type="number" name="price_per_session" id="priceInput" class="form-control" required>
          </div>

          <div class="mb-3">
            <label class="form-label">حالة البوكليت</label>
            <div class="form-check">
              <input type="checkbox" name="booklet_status" class="form-check-input" id="bookletCheck">
              <label class="form-check-label" for="bookletCheck">الطالب اشترى البوكليت</label>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">رصيد ابتدائي (اختياري)</label>
            <input type="number" name="balance" class="form-control" value="0">
          </div>

          <button type="submit" class="btn btn-primary w-100">حفظ الطالب</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    // لما يختار المادة، السعر يتعدل تلقائي
    const subjectSelect = document.getElementById('subjectSelect');
    const priceInput = document.getElementById('priceInput');

    subjectSelect.addEventListener('change', function () {
      const selectedOption = this.options[this.selectedIndex];
      const price = selectedOption.getAttribute('data-price');
      if (price) priceInput.value = price;
    });
  </script>
<%- include('partials/footer') %>