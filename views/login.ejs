<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Studyisfunny | تسجيل الدخول</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Cairo', sans-serif; }
    body {
      min-height: 100vh;
      display: flex; align-items: center;
      background: linear-gradient(135deg, #1E1B4B 0%, #4338CA 100%);
    }
    .login-card {
      border: none; border-radius: 20px;
      box-shadow: 0 20px 50px rgba(30,27,75,0.3);
      overflow: hidden;
    }
    .logo-mark {
      width: 56px; height: 56px; margin: 0 auto 10px;
      background: linear-gradient(135deg, #14B8A6, #4338CA);
      border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 800; font-size: 1.6rem;
    }
    .logo-text { text-align: center; font-weight: 800; font-size: 1.4rem; color: #1E1B4B; margin-bottom: 4px; }
    .logo-text span { color: #14B8A6; }
    .form-control { border-radius: 10px; padding: 0.7rem 1rem; }
    .btn-login {
      background: linear-gradient(135deg, #4338CA, #312E81);
      border: none; border-radius: 10px; font-weight: 700; padding: 0.7rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card login-card mx-auto p-4" style="max-width: 400px;">
      <div class="card-body">
        <div class="logo-mark">S</div>
        <div class="logo-text">Study<span>is</span>funny</div>
        <p class="text-center text-muted small mb-4">نظام متابعة الطلاب</p>

        <% if (error) { %><div class="alert alert-danger small"><%= error %></div><% } %>

        <form action="/login" method="POST">
          <div class="mb-3">
            <label class="form-label small fw-bold">اليوزرنيم</label>
            <input type="text" name="username" class="form-control" required autofocus>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-bold">الباسورد</label>
            <input type="password" name="password" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-login text-white w-100">دخول</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>